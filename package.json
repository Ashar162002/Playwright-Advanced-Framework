{
  "name": "playwright-advanced-framework",
  "version": "1.0.0",
  "description": "A modular, production-grade Playwright Page Object Model framework for UI end-to-end automation.",
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "postinstall": "playwright install",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/smoke",
    "test:regression": "playwright test tests/regression",
    "test:e2e": "playwright test tests/e2e",
    "test:healing": "playwright test tests/healing",
    "test:parallel": "playwright test --workers=4",
    "test:failed": "playwright test --last-failed --retries=0",
    "codegen": "playwright codegen https://www.saucedemo.com",
    "trace": "playwright show-trace",
    "report": "playwright show-report reports/html",
    "mcp": "playwright-mcp-server",
    "install:browsers": "playwright install"
  },
  "keywords": [
    "playwright",
    "automation",
    "page-object-model",
    "e2e",
    "testing",
    "sdet"
  ],
  "devDependencies": {
    "@executeautomation/playwright-mcp-server": "^1.0.12",
    "@playwright/test": "^1.57.0",
    "dotenv": "^16.4.0",
    "module-alias": "^2.2.3"
  },
  "_moduleAliases": {
    "@config": "config",
    "@fixtures": "fixtures",
    "@locators": "locators",
    "@pages": "pages",
    "@utils": "utils"
  }
}
