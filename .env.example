# Copy this file to `.env` and adjust as needed.
# Every value below has a sensible default in the config layer,
# so the suite runs out of the box without a .env file.

# Target environment: local | staging | prod
TEST_ENV=local

# Application under test
BASE_URL=https://www.saucedemo.com

# Runtime
HEADLESS=true
# Workers defaults to 1 on local, 4 on staging/prod (override here if needed)
# WORKERS=4
# Browser to run tests in: chromium | firefox | webkit
# Leave unset to run all three browsers
BROWSER=chromium

# Credentials (SauceDemo uses public shared credentials)
STANDARD_USERNAME=standard_user
LOCKED_OUT_USERNAME=locked_out_user
PROBLEM_USERNAME=problem_user
PERFORMANCE_USERNAME=performance_glitch_user
USER_PASSWORD=secret_sauce

# Self-healing locators (all optional; sensible defaults apply)
SELF_HEALING_ENABLED=true
SELF_HEALING_MODE=both
SELF_HEALING_CONFIDENCE_THRESHOLD=0.75
SELF_HEALING_TEST_ATTRIBUTE=data-test
# Tier 4 (AI) is skipped unless a key is provided
SELF_HEALING_AI_PROVIDER=openai
# SELF_HEALING_API_KEY=
